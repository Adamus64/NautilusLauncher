<Window x:Class="NautilusLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NautilusLauncher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#FFF0F0F0" Padding="3">
            <MenuItem Header="_Soubor">
                <MenuItem x:Name="menuAddApp" Header="Přidat aplikaci (.exe)" Click="MenuAddApp_Click"/>
                <Separator/>
                <MenuItem x:Name="menuExit" Header="Ukončit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="_Nastavení">
                <MenuItem x:Name="menuChangeCredentials" Header="Změnit jméno a heslo" Click="MenuChangeCredentials_Click"/>
            </MenuItem>
            <MenuItem Header="_Nápověda">
                <MenuItem x:Name="menuAbout" Header="O aplikaci" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top" Padding="5">
            <Button x:Name="btnRun" Content="▶ Spustit" FontWeight="Bold" Margin="0,0,10,0" Click="BtnRun_Click"/>
            <Button x:Name="btnAdd" Content="➕ Přidat .exe" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="btnEdit" Content="✎ Přejmenovat/Ikona" Margin="0,0,5,0" Click="BtnEdit_Click"/>
            <Button x:Name="btnDelete" Content="❌ Smazat" Margin="0,0,15,0" Foreground="DarkRed" Click="BtnDelete_Click"/>

            <Label Content="Seřadit podle:" VerticalAlignment="Center"/>
            <ComboBox x:Name="cmbSort" Width="120" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="A-Z (Výchozí)" IsSelected="True"/>
                <ComboBoxItem Content="Z-A"/>
                <ComboBoxItem Content="Nejnovější"/>
            </ComboBox>
        </ToolBar>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Připraveno. Vítejte v Nautilus Launcher."/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtAppCount" Text="Počet aplikací: 0"/>
            </StatusBarItem>
        </StatusBar>

        <ListView x:Name="AppListView" Margin="10" MouseDoubleClick="AppListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Ikona" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding ImagePath}" Width="32" Height="32" Margin="2"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Název aplikace" Width="300" DisplayMemberBinding="{Binding AppName}"/>
                    <GridViewColumn Header="Cesta k souboru" Width="350" DisplayMemberBinding="{Binding FilePath}"/>
                </GridView>
            </ListView.View>
        </ListView>

    </DockPanel>
</Window>
