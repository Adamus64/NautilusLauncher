<Window x:Class="NautilusLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nautilus Launcher" Height="500" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FFF5F5F7">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2" Padding="3">
            <MenuItem Header="Soubor">
                <MenuItem Header="Přidat aplikaci" Click="MenuAddApp_Click"/>
                <Separator/>
                <MenuItem Header="Ukončit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Nastavení">
                <MenuItem Header="Změnit údaje" Click="MenuChangeCredentials_Click"/>
            </MenuItem>
            <MenuItem Header="Nápověda">
                <MenuItem Header="O aplikaci" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="10" Background="White">
            <Button Content="➕ Přidat" Click="BtnAdd_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="✎ Upravit" Click="BtnEdit_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="❌ Smazat" Click="BtnDelete_Click" Width="80" Margin="0,0,10,0" Foreground="DarkRed"/>
            <Button Content="▶ Spustit" Click="BtnRun_Click" Width="80" Margin="0,0,20,0" FontWeight="Bold"/>

            <TextBlock Text="Řadit podle:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="CmbSort" Width="120" SelectionChanged="CmbSort_SelectionChanged">
                <ComboBoxItem Content="Názvu (A-Z)" IsSelected="True"/>
                <ComboBoxItem Content="Data přidání"/>
            </ComboBox>
        </StackPanel>

        <ListView x:Name="AppListView" Grid.Row="2" Grid.Column="0" Margin="10" MouseDoubleClick="AppListView_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Název aplikace" Width="200" DisplayMemberBinding="{Binding AppName}"/>
                    <GridViewColumn Header="Cesta k souboru" Width="300" DisplayMemberBinding="{Binding FilePath}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel x:Name="panelEdit" Grid.Row="2" Grid.Column="1" Margin="10" Background="#FFF0F0F0">
            <TextBlock Text="Detaily aplikace" FontWeight="Bold" Margin="5" TextAlignment="Center"/>

            <TextBlock Text="Název aplikace:" Margin="5,10,5,0"/>
            <TextBox x:Name="txtEditName" Margin="5"/>

            <TextBlock Text="Cesta k souboru (.exe):" Margin="5,10,5,0"/>
            <TextBox x:Name="txtEditIcon" Margin="5"/>

            <Button Content="Uložit změny" Margin="5,15,5,0" Padding="5" Background="LightGray"/>
        </StackPanel>
    </Grid>
</Window>