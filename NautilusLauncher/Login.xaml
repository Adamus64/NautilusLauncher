<Window x:Class="NautilusLauncher.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NautilusLauncher"
        mc:Ignorable="d"
        Title="Login" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch">

            <TextBlock Text="Nautilus Launcher" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Label Content="Uživatelské jméno:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtUsername" Margin="0,0,0,15" Padding="5" FontSize="14"/>

            <Label Content="Heslo:" FontWeight="SemiBold"/>
            <PasswordBox x:Name="txtPassword" Margin="0,0,0,10" Padding="5" FontSize="14"/>

            <TextBlock x:Name="txtErrorMessage" Text="Špatné jméno nebo heslo!" 
                       Foreground="Red" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <Button x:Name="btnLogin" Content="Přihlásit se" Height="35" FontSize="14" 
                    FontWeight="Bold" Background="#FF0078D7" Foreground="White" 
                    BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>
