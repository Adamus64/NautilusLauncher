<Window x:Class="NautilusLauncher.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nautilus - Přihlášení" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" Background="#FFF5F5F7">

    <StackPanel Width="250" VerticalAlignment="Center">
        <TextBlock Text="Přihlášení do systému" FontSize="20" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>

        <TextBlock Text="Uživatelské jméno:" Margin="0,0,0,5"/>
        <TextBox x:Name="txtUsername" Padding="5" Margin="0,0,0,10"/>

        <TextBlock Text="Heslo:" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Padding="5" Margin="0,0,0,20"/>

        <TextBlock x:Name="txtError" Foreground="Red" TextAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed"/>

        <Button Content="Přihlásit se" Padding="10" Background="#FF0078D7" Foreground="White" FontWeight="Bold" Click="BtnLogin_Click" IsDefault="True"/>
    </StackPanel>
</Window>